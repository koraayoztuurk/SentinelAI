# Base URL of the SentinelAI Backend API. The frontend communicates with the
# platform exclusively through this single API boundary.
VITE_API_BASE_URL=http://localhost:8000

# Development-only auto sign-in (ES-054): set in `.env.local` (gitignored) to
# skip typing the dev credential in the header field. Dev-server builds only —
# production builds never receive it. Format: <subject>:<DEV_AUTH_TOKEN>.
# VITE_DEV_AUTH_CREDENTIAL=analyst:change_me
