# ============================================================
# SentinelAI
# Environment Configuration
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_NAME=SentinelAI
# APP_ENV is one of: development | test | staging | production.
# Non-development environments must replace every "change_me" secret below with a
# real value — the application fails fast on startup otherwise.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# LOG_FORMAT is one of: text (human-readable, local dev) | json (structured, for
# containers/production). An invalid value is rejected fail-fast on startup.
LOG_FORMAT=text

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------

# Inside the compose network the host is the service name "postgres". The
# `data` profile also publishes 127.0.0.1:5432, so a backend or the live test
# suite running on the host uses POSTGRES_HOST=localhost.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=change_me

# ------------------------------------------------------------
# Neo4j
# ------------------------------------------------------------

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# ------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------

QDRANT_URL=http://qdrant:6333

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------
# AI
# ------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Consumed through the SecretProvider by the Gemini LLM adapter (ES-043).
GOOGLE_API_KEY=
# Consumed through the SecretProvider by the NVIDIA NIM LLM adapter (ES-054).
NVIDIA_API_KEY=

# Active LLM adapter: gemini (default) | nvidia (ES-054). The embedding
# provider stays on Gemini regardless (the Qdrant collection's vector
# dimension is bound to it, ES-050).
# LLM_PROVIDER=gemini

# NVIDIA NIM adapter configuration (defaults shown; the key is above).
# NVIDIA_MODEL=minimaxai/minimax-m3
# NVIDIA_TIMEOUT_SECONDS=90
# NVIDIA_TEMPERATURE=0
# NVIDIA_MAX_TOKENS=8192

# Gemini adapter configuration (defaults shown; the key is above, never here).
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_TIMEOUT_SECONDS=30
# GEMINI_TEMPERATURE=0

# Gemini embedding adapter (ES-049/050; same GOOGLE_API_KEY, separate model/bound).
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_TIMEOUT_SECONDS=30
# Fixed embedding dimension (must match the Qdrant collection's vector size).
# GEMINI_EMBEDDING_DIMENSIONS=768

# ------------------------------------------------------------
# Authentication (development-grade, ES-046)
# ------------------------------------------------------------

# Shared bearer secret for the dev authenticator. Clients send
#   Authorization: Bearer <subject>:<DEV_AUTH_TOKEN>
# Unset => every protected request is rejected (401, secure by default).
# The production identity provider replaces this in a later phase.
DEV_AUTH_TOKEN=

# Cycle budget of the synchronous investigation run surface (default 3).
# RUN_CYCLE_BUDGET=3