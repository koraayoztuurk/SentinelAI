# ------------------------------------------------------------
# Neo4j
# ------------------------------------------------------------

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# ------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------

QDRANT_URL=http://qdrant:6333

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------
# AI
# ------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
