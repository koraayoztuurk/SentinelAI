# ============================================================
# SentinelAI
# Environment Configuration
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

APP_NAME=SentinelAI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinelai
